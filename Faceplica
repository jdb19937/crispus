# Faceplica — libcrispus.a
# Bibliotheca retis HTTPS sine dependentiis externis.

CC      ?= cc
CFLAGS  ?= -Wall -Wextra -pedantic -std=c99 -O2
AR      ?= ar
ARFLAGS = rcs

FONTES  = crispus.c velum.c summa.c arcana.c numerus.c
OBIECTA = $(FONTES:.c=.o)

BIBLIOTHECA = libcrispus.a

omnia: $(BIBLIOTHECA) crispe

$(BIBLIOTHECA): $(OBIECTA)
	$(AR) $(ARFLAGS) $@ $^

%.o: %.c
	$(CC) $(CFLAGS) -c -o $@ $<

crispe: $(BIBLIOTHECA) crispe.o
	$(CC) $(CFLAGS) -o $@ crispe.o -L. -lcrispus

crispe.o: crispe.c crispus.h
	$(CC) $(CFLAGS) -c -o $@ $<

proba: $(BIBLIOTHECA) proba.o
	$(CC) $(CFLAGS) -o $@ proba.o -L. -lcrispus

proba.o: proba.c proba.h crispus.h internum.h arcana.h
	$(CC) $(CFLAGS) -c -o $@ $<

PREFIX = /opt/apotheca

colloca: omnia
	install -d $(PREFIX)/bin $(PREFIX)/lib $(PREFIX)/include/crispus
	install -m 755 crispe $(PREFIX)/bin/
	install -m 644 $(BIBLIOTHECA) $(PREFIX)/lib/
	install -m 644 crispus.h arcana.h $(PREFIX)/include/crispus/

purga:
	rm -f $(OBIECTA) proba.o crispe.o $(BIBLIOTHECA) proba crispe

linte:
	insinulint -c *.c *.h

.PHONY: omnia colloca purga proba
